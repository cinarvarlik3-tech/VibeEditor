GOOGLE_FONTS_API_KEY=
OPENAI_API_KEY=

# Gemini API for AI image generation (Scan for Visuals → AI Generate)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# AI model routing — override to test different model tiers
# OPENAI_MODEL_FLAGSHIP=gpt-5.4
# OPENAI_MODEL_MINI=gpt-5.4-mini
# OPENAI_MODEL_NANO=gpt-5.4-nano

# Token/cost optimization feature flags (set false to roll back one layer)
FEATURE_MODEL_ROUTING=true
FEATURE_TRANSCRIPT_WINDOWING=true
FEATURE_HISTORY_SUMMARIES=true
FEATURE_PROMPT_BUNDLES=true

# When true (default), past user turns carry only PROMPT — no CLIP_SUMMARY, no tracks,
# no transcript. Full snapshots are only included when the current prompt uses
# conversational reference words like "undo that" or "do the same".
# FEATURE_MINIMAL_HISTORY=true
FREESOUND_API_KEY=
JAMENDO_CLIENT_ID=
PIXABAY_API_KEY=your_key_here
PORT=3000

# Set to false to disable transcript DB cache and render disk cache.
CACHE_ENABLED=true

# In-memory LLM response memoization (duplicate identical requests; per authenticated user).
# Max = max entries per cache; TTL = milliseconds.
LLM_RESPONSE_CACHE_MAX=200
LLM_RESPONSE_CACHE_TTL_MS=300000
LLM_SUMMARIZE_CACHE_MAX=80
LLM_SUMMARIZE_CACHE_TTL_MS=1800000
LLM_VISUAL_SCAN_CACHE_MAX=60
LLM_VISUAL_SCAN_CACHE_TTL_MS=900000
LLM_VISUAL_BRIEF_CACHE_MAX=200
LLM_VISUAL_BRIEF_CACHE_TTL_MS=900000
LLM_VISUAL_PICK_CACHE_MAX=400
LLM_VISUAL_PICK_CACHE_TTL_MS=900000

# Supabase Auth — Dashboard → Settings → API (service key stays server-only; anon is safe in browser)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
